# Copy this file to `.env` for local development.
# Keep real secrets in your local `.env` and out of git.

# Core product/runtime settings
NEXUS_DATABASE_PATH=artifacts/incidents.json
NEXUS_WEBHOOK_SIGNING_SECRET=nexus-demo-webhook-secret
NEXUS_ALLOWED_TENANT_IDS=tenant-a,tenant-system
NEXUS_FORGE_MODEL_NAME=gpt-4o

# Optional live demo / OpenAI path
NEXUS_USE_OPENAI=0
OPENAI_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o
