# NEXUS Environment Variables
# Copy this file to .env and fill in your values for local development or deployment

# Environment mode
# Use 'demo' or 'development' for local development (defaults to 'demo'); use 'production' for live deployment
APP_ENV=demo

# Database configuration
# Where the SQLite database is stored. The live artifact intentionally keeps the legacy
# incidents.json filename for compatibility even though the file content is SQLite.
NEXUS_DATABASE_PATH=artifacts/incidents.json

# Webhook authentication
# Random secret for validating incoming webhook signatures; generate with: python -c 'import secrets; print(secrets.token_hex(32))'
NEXUS_WEBHOOK_SIGNING_SECRET=nexus-demo-webhook-secret

# Multi-tenancy configuration
# Comma-separated list of tenant IDs permitted to use the system
NEXUS_ALLOWED_TENANT_IDS=tenant-a,tenant-system

# LLM configuration for reasoning
# Model name to use for live LLM reasoning (e.g., gpt-4o, gpt-4-turbo)
NEXUS_FORGE_MODEL_NAME=gpt-4o

# OpenAI integration
# Set to 1 to enable live OpenAI reasoning; set to 0 or unset to use deterministic fallback responses
NEXUS_USE_OPENAI=0

# OpenAI API Key
# Required if NEXUS_USE_OPENAI=1; get from https://platform.openai.com/api-keys (starts with sk-proj-)
OPENAI_API_KEY=sk-proj-your-api-key-here

# CORS configuration
# Comma-separated list of origins allowed to make cross-origin requests to the API
# Default includes localhost and common deployment URLs; add your frontend URLs here
NEXUS_ALLOWED_ORIGINS=http://localhost:7860,http://127.0.0.1:7860,http://nexus-triage.duckdns.org:7860,https://nexus-uny5.onrender.com

# Request size limits
# Maximum request body size in bytes; default is 1MB (1048576)
# Applies to webhook payloads, raw text incident reports, and other POST bodies
NEXUS_MAX_REQUEST_SIZE_BYTES=1048576

# Optional: Runtime host configuration (for bounded REPLICA replay)
# Base URL of the runtime host service (only needed if using Docker-based replay)
# NEXUS_RUNTIME_HOST_BASE_URL=http://runtime-host:7860

# Optional: Runtime host authentication token
# Shared token for authenticating with the runtime host service
# NEXUS_RUNTIME_HOST_SHARED_TOKEN=nexus-runtime-host-token
